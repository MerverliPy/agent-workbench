{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/dist/",
      "!**/build/",
      "!**/coverage/",
      "!**/node_modules/",
      "!**/.hermes/",
      "!**/.opencode/",
      "!**/apps/**/*/dist/",
      "!**/apps/**/*/build/",
      "!**/apps/cli/templates/",
      "!**/tools/",
      "!**/plugins/"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true
  }
}
