{
  "name": "@agent-workbench/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SQLite/Drizzle schema, migrations, and repositories.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.0"
  }
}
