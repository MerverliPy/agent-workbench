{
  "name": "@agent-workbench/compliance",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Enterprise compliance features: immutable audit trail, data retention, PII detection, and air-gapped mode helpers.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./audit": {
      "types": "./dist/audit.d.ts",
      "default": "./dist/audit.js"
    },
    "./data-retention": {
      "types": "./dist/data-retention.d.ts",
      "default": "./dist/data-retention.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-workbench/protocol": "*",
    "@agent-workbench/storage": "*",
    "drizzle-orm": "^0.45.2",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14"
  }
}
