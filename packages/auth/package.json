{
  "name": "@agent-workbench/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Bearer token authentication, TLS configuration, and time-limited session tokens for remote access.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth-middleware": {
      "types": "./dist/auth-middleware.d.ts",
      "default": "./dist/auth-middleware.js"
    },
    "./tls-config": {
      "types": "./dist/tls-config.d.ts",
      "default": "./dist/tls-config.js"
    },
    "./session-tokens": {
      "types": "./dist/session-tokens.d.ts",
      "default": "./dist/session-tokens.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-workbench/protocol": "workspace:*",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "hono": "^4.12.27"
  }
}
