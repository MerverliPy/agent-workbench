{
  "name": "@agent-workbench/protocol",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Zod schemas, route contracts, error envelopes, event envelopes, and OpenAPI metadata.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./routes": {
      "types": "./dist/routes/index.d.ts",
      "default": "./dist/routes/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi/index.d.ts",
      "default": "./dist/openapi/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^9.1.0",
    "zod": "^4.4.3"
  }
}
